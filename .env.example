STORAGE_DIR=/absolute/path/to/your/project/storage
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
JWT_ACCESS_EXP_MINUTES=15
JWT_REFRESH_EXP_DAYS=7

# YOLO Model Configuration
# Set to "auto" for automatic model selection based on hardware
# Options: auto, yolov8n.pt, yolov8s.pt, yolov8m.pt, yolov8l.pt, yolov8x.pt
YOLO_MODEL=auto
YOLO_CONFIDENCE=0.35
YOLO_IOU=0.45
YOLO_IMGSZ=960
YOLO_DEVICE=auto

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_DIR=logs

# Request handling
REQUEST_TIMEOUT=30
MAX_UPLOAD_SIZE=10485760

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Security
MIN_PASSWORD_LENGTH=8

# Database Configuration
# Choose between local JSON storage (default) or MongoDB
# Local JSON: Files stored in STORAGE_DIR directory
# MongoDB: Requires MongoDB connection string and proper IP whitelist

ENABLE_MONGODB=false

# MongoDB Connection String
# IMPORTANT: If your password contains special characters (@, :, etc.), URL-encode them:
# @ becomes %40, : becomes %3A, etc.
# Example: mongodb+srv://username:password%40123@cluster.mongodb.net
#
# For local MongoDB: mongodb://localhost:27017
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net
# For Docker: mongodb://mongodb:27017

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=smart_campus
